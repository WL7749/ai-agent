# Application
SECRET_KEY=change-me-to-a-random-secret-key
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_agent
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/ai_agent

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# DeepSeek LLM (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Embedding (DeepSeek 暂无独立 embedding，MVP 使用 mock/后续可换 BGE)
EMBEDDING_DIMENSION=1536

# Weather API (optional)
OPENWEATHER_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
